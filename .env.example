# ============================================================
# Chandramonians Web — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ============================================================

# Django Core
SECRET_KEY=your-very-long-random-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Development: leave as-is (uses SQLite)
# Production: set to your PostgreSQL URL from Railway/Render
DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Email (optional — for contact form and notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Google Gemini AI (free — get from https://aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key-here

# Google Sheets Sync (for member payment data)
# 1. Create a Service Account at console.cloud.google.com
# 2. Enable Google Sheets API + Google Drive API
# 3. Download the service account JSON
# 4. Base64-encode it: base64 credentials.json (Linux/Mac)
#    or: [Convert]::ToBase64String([IO.File]::ReadAllBytes("credentials.json")) (PowerShell)
# 5. Paste the base64 string below
GOOGLE_CREDS_JSON=base64-encoded-service-account-json-here
GOOGLE_SHEET_ID=1X4T058McT6GTnmUyu1OsmLua9BwKPEz03Rr-rbcMRvs

# Site URL (used in emails and social sharing)
SITE_URL=http://localhost:8000
